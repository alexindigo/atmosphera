// Atmosphera Niri Configuration
// Install: include this from ~/.config/niri/config.kdl or use atmosphera-niri-setup

// --- Blur ---
blur {
    passes 2
    offset 3.0
    noise 0.03
    saturation 1.0
}

// --- xray false on all atmosphera surfaces ---
// ext-background-effect handles actual blur shapes; niri-side blur conflicts.
layer-rule {
    match namespace="^atmosphera-.*$"
    background-effect {
        xray false
    }
}

// --- Notifications: no background-effect ---
// Notification surfaces have transparent shadow-padding halo; any effect here
// would carve a rectangle out of windows below.
layer-rule {
    match namespace="^atmosphera-notifications.*"
    background-effect {
        blur false
        xray false
    }
}

// --- Backdrop ---
// Surfaces with the atmosphera-backdrop- namespace prefix are placed
// into the Niri backdrop (visible between workspaces and during overview).
// The shell controls which surfaces use this namespace at runtime.
layer-rule {
    match namespace="^atmosphera-backdrop-.*$"
    place-within-backdrop true
}

// --- Workspace background ---
layout {
    background-color "transparent"
}
