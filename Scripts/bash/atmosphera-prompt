#!/bin/bash
set -euo pipefail

question="${1:?Usage: atmosphera-prompt <question> [default]}"
default="${2:-}"
[ "$default" = "-" ] && default=""

fifo=$(mktemp -u /dev/shm/atmosphera-prompt-XXXXXXXX)
mkfifo "$fifo"

QS="${ATMOSPHERA_QS:-qs}"
PID="${ATMOSPHERA_PID:-$(pgrep -n -x qs 2>/dev/null || true)}"
TARGET=""
[ -n "$PID" ] && TARGET="--pid $PID"

cleanup() {
  $QS ipc $TARGET call dialog cancel &>/dev/null || true
}
trap cleanup EXIT INT TERM

$QS ipc $TARGET call dialog prompt "$question" "$fifo" "$default" &>/dev/null &

read -t 86400 result < "$fifo" 2>/dev/null || true
rm -f "$fifo" 2>/dev/null || true
echo "${result:-}"
